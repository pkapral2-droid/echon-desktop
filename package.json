{
  "name": "echon",
  "version": "2.4.3",
  "description": "Echon - Your space to talk, share, and connect with communities that matter to you.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:linux": "electron-builder --linux"
  },
  "author": "Echon",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.echon.voice",
    "productName": "Echon",
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echon",
      "artifactName": "Echon-Setup.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.social-networking",
      "artifactName": "Echon-${arch}.dmg",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "category": "Network",
      "artifactName": "Echon-${arch}.${ext}",
      "desktop": {
        "Name": "Echon",
        "Comment": "Privacy-first voice chat",
        "Categories": "Network;InstantMessaging;Chat;"
      }
    },
    "dmg": {
      "title": "Echon",
      "iconSize": 80,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "pkapral2-droid",
      "repo": "echon-desktop"
    },
    "afterPack": "./afterPack.js",
    "asarUnpack": [
      "node_modules/uiohook-napi/**",
      "node_modules/node-gyp-build/**"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-picker.js",
      "icon.png",
      "tray.png",
      "node_modules/node-global-key-listener/**/*",
      "node_modules/uiohook-napi/**/*",
      "node_modules/node-gyp-build/**/*",
      "node_modules/electron-updater/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-global-key-listener": "^0.3.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5"
  }
}
