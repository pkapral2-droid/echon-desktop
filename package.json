{
  "name": "echon",
  "version": "2.3.3",
  "description": "Echon - Your space to talk, share, and connect with communities that matter to you.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "author": "Echon",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.echon.voice",
    "productName": "Echon",
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echon",
      "artifactName": "Echon-Setup.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "pkapral2-droid",
      "repo": "echon-desktop"
    },
    "afterPack": "./afterPack.js",
    "asarUnpack": [
      "node_modules/uiohook-napi/**",
      "node_modules/node-gyp-build/**"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "tray.png",
      "node_modules/node-global-key-listener/**/*",
      "node_modules/uiohook-napi/**/*",
      "node_modules/node-gyp-build/**/*",
      "node_modules/electron-updater/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-global-key-listener": "^0.3.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5"
  }
}
